{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": "python3 ~/.cursor/hooks/vibenotif.py",
        "timeout": 10
      }
    ],
    "beforeSubmitPrompt": [
      {
        "command": "python3 ~/.cursor/hooks/vibenotif.py",
        "timeout": 10
      }
    ],
    "preToolUse": [
      {
        "command": "python3 ~/.cursor/hooks/vibenotif.py",
        "timeout": 10
      }
    ],
    "preCompact": [
      {
        "command": "python3 ~/.cursor/hooks/vibenotif.py",
        "timeout": 10
      }
    ],
    "subagentStart": [
      {
        "command": "python3 ~/.cursor/hooks/vibenotif.py",
        "timeout": 10
      }
    ],
    "subagentStop": [
      {
        "command": "python3 ~/.cursor/hooks/vibenotif.py",
        "timeout": 10
      }
    ],
    "sessionEnd": [
      {
        "command": "python3 ~/.cursor/hooks/vibenotif.py",
        "timeout": 10
      }
    ],
    "stop": [
      {
        "command": "python3 ~/.cursor/hooks/vibenotif.py",
        "timeout": 10
      }
    ]
  }
}
